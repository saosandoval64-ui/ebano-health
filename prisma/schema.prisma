generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
  CLINIC_ADMIN
}

enum AppointmentStatus {
  PENDING
  RESERVED
  COMPLETED
  CANCELLED
}

model User {
  id             String    @id @default(cuid())
  name           String    // Nombre
  lastName       String?   // Apellido
  email          String    @unique
  password       String
  role           Role      @default(PATIENT)

  // Google OAuth
  googleId       String?   @unique

  // Campos específicos para el registro de pacientes (Guía de Acceso Paso 2)
  dni            String?   @unique // DNI / Documento único
  phone          String?   // Teléfono de contacto
  birthDate      DateTime? // Fecha de nacimiento
  insurance      String?   // Obra Social / Prepaga (Opcional)
  avatar         String    @default("1") // Avatar selector ID

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relaciones
  doctorProfile  DoctorProfile?
  clinic         Clinic?  // Si es CLINIC_ADMIN, la clínica que administra
  appointmentsAsPatient Appointment[] @relation("PatientAppointments")
  followedDoctors FavoriteDoctor[]
  medicalRecordsAsPatient MedicalRecord[]
  medicalDocuments MedicalDocument[]
  notifications   Notification[]
}

model DoctorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  specialty   String   // Especialidad (ej: Pediatría, Cardiología, etc.)
  license     String   // Matrícula médica profesional
  bio         String?  // Breve descripción o presentación
  imageUrl    String?  // Foto del profesional

  // Clínica asociada (opcional - null = consultorio individual)
  clinicId    String?
  clinic      Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  appointments  Appointment[] @relation("DoctorAppointments")
  availability  Availability[]
  followedBy    FavoriteDoctor[]
  medicalRecords MedicalRecord[]
  uploadedDocuments MedicalDocument[]
}

model Availability {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  dayOfWeek Int      // 0=Lunes, 1=Martes ... 6=Domingo
  startTime String   // "09:00"
  endTime   String   // "17:00"
  isActive  Boolean  @default(true)

  @@unique([doctorId, dayOfWeek])
}

model Appointment {
  id          String            @id @default(cuid())

  // Relación con el Paciente (User)
  patientId   String
  patient     User              @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)

  // Relación con el Perfil del Médico
  doctorId    String
  doctor      DoctorProfile     @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)

  dateTime    DateTime          // Fecha y hora exacta del turno agendado
  status      AppointmentStatus @default(RESERVED) // Estado: RESERVED por defecto (Paso 7)

  // Reprogramación
  originalAppointmentId String?
  rescheduledFrom       Appointment? @relation("RescheduledAppointments", fields: [originalAppointmentId], references: [id])
  rescheduledAppointments Appointment[] @relation("RescheduledAppointments")

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relaciones
  medicalRecord MedicalRecord?
}

model MedicalRecord {
  id          String   @id @default(cuid())
  
  patientId   String
  patient     User     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  appointmentId String? @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  // Datos clínicos
  consultationDate DateTime @default(now())
  reason           String   // Motivo de consulta
  diagnosis        String   // Diagnóstico
  treatment        String?  // Tratamiento indicado
  notes            String?  // Notas adicionales del médico
  prescriptions    String?  // Medicamentos recetados
  vitalSigns       String?  // Signos vitales (JSON: tension, temperatura, peso, etc.)
  
  // Seguimiento
  followUpDate     DateTime? // Próxima cita de control
  followUpNotes    String?   // Notas de seguimiento

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
}

model Notification {
  id        String   @id @default(cuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      String   // APPOINTMENT_REMINDER, APPOINTMENT_CONFIRMED, FOLLOW_UP, MEDICATION, GENERAL
  title     String
  message   String
  read      Boolean  @default(false)
  
  // Datos extras (JSON)
  metadata  String?  // appointmentId, patientId, etc.
  
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model FavoriteDoctor {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  createdAt DateTime @default(now())

  patient User          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([patientId, doctorId])
}

model MedicalDocument {
  id          String   @id @default(cuid())
  patientId   String
  patient     User     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String?
  doctor      DoctorProfile? @relation(fields: [doctorId], references: [id])
  title       String
  description String?
  fileUrl     String
  fileType    String   // "lab_result", "imaging", "prescription", "other"
  uploadedAt  DateTime @default(now())

  @@index([patientId])
}

model Clinic {
  id          String   @id @default(cuid())
  name        String   // Nombre de la clínica u hospital
  slug        String   @unique // URL-friendly: "clinica-san-jose"
  description String?  // Descripción de la clínica
  logo        String?  // Logo de la clínica
  phone       String?  // Teléfono de contacto
  email       String?  // Email de contacto
  address     String?  // Dirección física
  website     String?  // Sitio web

  // Admin de la clínica (CLINIC_ADMIN)
  adminId     String   @unique
  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  doctors     DoctorProfile[]
}

model ContactForm {
  id          String    @id @default(cuid())
  nombre      String
  email       String
  asunto      String
  mensaje     String    @db.Text
  leido       Boolean   @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}